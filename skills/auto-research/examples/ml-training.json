{
  "tag": "ml-opt",
  "modifiable_files": ["train.py"],
  "readonly_files": ["prepare.py", "README.md"],
  "run_command": "uv run train.py",
  "metric_grep": "^val_bpb:",
  "metric_name": "val_bpb",
  "metric_direction": "lower",
  "secondary_metrics": ["^peak_vram_mb:"],
  "timeout_seconds": 600
}
